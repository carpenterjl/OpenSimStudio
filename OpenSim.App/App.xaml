<Application x:Class="OpenSim.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:OpenSim.App">
    <Application.Resources>
        <!-- Converters at application scope: the panel UserControls resolve
             StaticResource against their own + application dictionaries only. -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>

        <!-- The dark implicit styles live at application scope so AvalonDock's
             FLOATING pane windows (separate top-level windows outside MainWindow's
             resource scope) keep the same look as docked panes. -->
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="BorderBrush" Value="#3A3A44"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#33333E"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="BorderBrush" Value="#4A4A58"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A32"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="BorderBrush" Value="#4A4A58"/>
            <Setter Property="Padding" Value="3,1"/>
            <Setter Property="Margin" Value="2,1"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#C9C9D2"/>
            <Setter Property="Padding" Value="2"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C9C9D2"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="2,1"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#2A2A32"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="BorderBrush" Value="#4A4A58"/>
        </Style>
    </Application.Resources>
</Application>
