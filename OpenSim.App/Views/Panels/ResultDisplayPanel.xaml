<UserControl x:Class="OpenSim.App.Views.Panels.ResultDisplayPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <GroupBox Header="Result display">
        <StackPanel>
            <UniformGrid Columns="2">
                <Label Content="Deform scale"/>
                <TextBox Text="{Binding Results.DeformScale}"/>
            </UniformGrid>
            <CheckBox Content="Viridis colormap" IsChecked="{Binding Results.UseViridis}"
                      Foreground="#C9C9D2" Margin="2,4"/>
            <DockPanel Margin="2,0">
                <Label Content="Max clamp" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                <Slider Minimum="0.05" Maximum="1" SmallChange="0.02" LargeChange="0.1"
                        Value="{Binding Results.ResultClampFraction, Delay=150}" Margin="4,0"
                        ToolTip="Drag left to clamp the colormap maximum: values above saturate at the top color so fine low-value gradients become visible"/>
            </DockPanel>
            <CheckBox Content="Contour lines" IsChecked="{Binding Results.ShowContours}"
                      Foreground="#C9C9D2" Margin="2,4"
                      ToolTip="Iso-value lines of the displayed field on the surface"/>
            <CheckBox Content="Section plane" IsChecked="{Binding Results.SectionEnabled}"
                      Foreground="#C9C9D2" Margin="2,4"
                      ToolTip="Cut the model open; the cross-section is colored by the same field"/>
            <DockPanel IsEnabled="{Binding Results.SectionEnabled}" Margin="2,0">
                <ComboBox DockPanel.Dock="Left" Width="52"
                          ItemsSource="{Binding Results.SectionAxisOptions}"
                          SelectedItem="{Binding Results.SectionAxis}"/>
                <CheckBox Content="Flip" DockPanel.Dock="Right" VerticalAlignment="Center"
                          IsChecked="{Binding Results.SectionFlip}" Foreground="#C9C9D2" Margin="4,0,0,0"
                          ToolTip="Keep the other side of the plane"/>
                <Slider Minimum="0" Maximum="1" SmallChange="0.02" LargeChange="0.1"
                        Value="{Binding Results.SectionOffsetFraction, Delay=150}" Margin="4,0"
                        ToolTip="Plane position along the axis (fraction of the model extent)"/>
            </DockPanel>
        </StackPanel>
    </GroupBox>
</UserControl>
