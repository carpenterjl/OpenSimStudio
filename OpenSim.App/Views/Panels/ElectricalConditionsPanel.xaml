<UserControl x:Class="OpenSim.App.Views.Panels.ElectricalConditionsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <GroupBox Header="Electrical conditions (select faces first)"
              Visibility="{Binding Session.IsElectricalAnalysis, Converter={StaticResource BoolToVis}}">
        <StackPanel>
            <UniformGrid Columns="2">
                <Label Content="Voltage [V]"/>
                <TextBox Text="{Binding Conditions.VoltageValue}"/>
            </UniformGrid>
            <Button Content="Add voltage" Command="{Binding Conditions.AddVoltageCommand}"/>
            <UniformGrid Columns="2" Margin="0,6,0,0">
                <Label Content="Current [A]"/>
                <TextBox Text="{Binding Conditions.CurrentValue}"/>
            </UniformGrid>
            <Button Content="Add current flow" Command="{Binding Conditions.AddCurrentCommand}"/>
        </StackPanel>
    </GroupBox>
</UserControl>
