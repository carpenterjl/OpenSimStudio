<UserControl x:Class="OpenSim.App.Views.Panels.ThermalConditionsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <GroupBox Header="Thermal conditions (select faces first)"
              Visibility="{Binding Session.IsThermalAnalysis, Converter={StaticResource BoolToVis}}">
        <StackPanel>
            <UniformGrid Columns="2">
                <Label Content="Temperature [K]"/>
                <TextBox Text="{Binding Conditions.TemperatureValue}"/>
            </UniformGrid>
            <Button Content="Add fixed temperature" Command="{Binding Conditions.AddTemperatureCommand}"/>
            <UniformGrid Columns="2" Margin="0,6,0,0">
                <Label Content="Heat flow [W]"/>
                <TextBox Text="{Binding Conditions.HeatPowerValue}"/>
            </UniformGrid>
            <Button Content="Add heat flow" Command="{Binding Conditions.AddHeatFluxCommand}"/>
            <UniformGrid Columns="2" Margin="0,6,0,0">
                <Label Content="h [W/(m²·K)]"/>
                <TextBox Text="{Binding Conditions.ConvectionCoefficient}"/>
                <Label Content="Ambient [K]"/>
                <TextBox Text="{Binding Conditions.AmbientTemperature}"/>
            </UniformGrid>
            <Button Content="Add convection" Command="{Binding Conditions.AddConvectionCommand}"/>
        </StackPanel>
    </GroupBox>
</UserControl>
