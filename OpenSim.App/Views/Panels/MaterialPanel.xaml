<UserControl x:Class="OpenSim.App.Views.Panels.MaterialPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <GroupBox Header="Material"
              Visibility="{Binding Session.IsPcbMode, Converter={StaticResource InverseBoolToVis}}">
        <StackPanel>
            <ComboBox ItemsSource="{Binding Materials.Materials}" SelectedItem="{Binding Session.SelectedMaterial}"
                      DisplayMemberPath="Name"/>
            <UniformGrid Columns="2" Margin="0,4,0,0">
                <Label Content="E [Pa]"/>
                <TextBlock Text="{Binding Session.SelectedMaterial.YoungsModulus, StringFormat=g4}" VerticalAlignment="Center"/>
                <Label Content="ν"/>
                <TextBlock Text="{Binding Session.SelectedMaterial.PoissonRatio}" VerticalAlignment="Center"/>
                <Label Content="ρ [kg/m³]"/>
                <TextBlock Text="{Binding Session.SelectedMaterial.Density}" VerticalAlignment="Center"/>
            </UniformGrid>
            <UniformGrid Columns="2"
                         Visibility="{Binding Session.IsThermalAnalysis, Converter={StaticResource BoolToVis}}">
                <Label Content="k [W/(m·K)]"/>
                <TextBlock Text="{Binding Session.SelectedMaterial.ThermalConductivity, StringFormat=g4}" VerticalAlignment="Center"/>
            </UniformGrid>
            <UniformGrid Columns="2"
                         Visibility="{Binding Session.IsElectricalAnalysis, Converter={StaticResource BoolToVis}}">
                <Label Content="σ [S/m]"/>
                <TextBlock Text="{Binding Session.SelectedMaterial.ElectricalConductivity, StringFormat=g4}" VerticalAlignment="Center"/>
            </UniformGrid>
            <Button Content="Edit materials…" Command="{Binding Materials.EditMaterialsCommand}" Margin="0,4,0,0"/>
        </StackPanel>
    </GroupBox>
</UserControl>
