<UserControl x:Class="OpenSim.App.Views.Panels.ElectricalSetupPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <GroupBox Header="Electrical simulation setup"
              Visibility="{Binding Session.IsElectricalAnalysis, Converter={StaticResource BoolToVis}}">
        <StackPanel>
            <!-- Step 1: net + mesh -->
            <TextBlock Text="1. Net" FontWeight="Bold" Margin="0,0,0,2"/>
            <TextBlock Text="{Binding Pcb.SelectedNet.Label, FallbackValue='No net selected — pick one in the PCB nets list or click copper in the view.'}"
                       TextWrapping="Wrap" Margin="0,0,0,2"/>
            <TextBlock Text="Mesh the net from the Meshing panel." FontSize="11"
                       Foreground="#8A8A96" Margin="0,0,0,2"/>

            <!-- Step 2: electrodes -->
            <TextBlock Text="2. Electrodes" FontWeight="Bold" Margin="0,8,0,2"/>
            <TextBlock Text="{Binding Electrodes.ElectrodeInfo}" TextWrapping="Wrap" Margin="0,0,0,4"
                       Foreground="#C9C9D2"/>
            <UniformGrid Columns="2">
                <Label Content="Source (＋)"/>
                <ComboBox x:Name="SourceCombo"
                          ItemsSource="{Binding Electrodes.PadElectrodes}" SelectedItem="{Binding Electrodes.SelectedSource}"
                          DisplayMemberPath="Label"/>
                <Label Content="Sink (0 V)"/>
                <ComboBox x:Name="SinkCombo"
                          ItemsSource="{Binding Electrodes.PadElectrodes}" SelectedItem="{Binding Electrodes.SelectedSink}"
                          DisplayMemberPath="Label"/>
            </UniformGrid>
            <TextBlock Text="Gold = selectable pad, green = source, red = sink. Click pads in the view to assign."
                       TextWrapping="Wrap" FontSize="11" Foreground="#8A8A96" Margin="0,2,0,0"/>

            <!-- Step 3: excitation + solve -->
            <TextBlock Text="3. Excitation &amp; solve" FontWeight="Bold" Margin="0,8,0,2"/>
            <UniformGrid Columns="2">
                <RadioButton x:Name="VoltageDrive" Content="Voltage [V]" GroupName="Excitation"
                             IsChecked="True" Foreground="#C9C9D2"
                             VerticalAlignment="Center" Margin="2,1"/>
                <TextBox Text="{Binding Electrodes.TestVoltage}"
                         IsEnabled="{Binding IsChecked, ElementName=VoltageDrive}"/>
                <RadioButton x:Name="CurrentDrive" Content="Current [A]" GroupName="Excitation"
                             IsChecked="{Binding Electrodes.DriveWithCurrent, Mode=TwoWay}" Foreground="#C9C9D2"
                             VerticalAlignment="Center" Margin="2,1"
                             ToolTip="Inject this current at the source pad; the sink is held at 0 V"/>
                <TextBox Text="{Binding Electrodes.TestCurrent}"
                         IsEnabled="{Binding IsChecked, ElementName=CurrentDrive}"/>
            </UniformGrid>
            <Button Content="Run electrical test" Command="{Binding Electrodes.RunElectricalTestCommand}"/>
            <TextBlock Text="{Binding Electrodes.ElectricalResult}" TextWrapping="Wrap"
                       FontWeight="Bold" Foreground="#FFD060" Margin="0,4,0,0"/>

            <!-- Step 4: lumped AC impedance estimate -->
            <TextBlock Text="4. AC impedance (R + jωL estimate)" FontWeight="Bold" Margin="0,8,0,2"/>
            <UniformGrid Columns="2">
                <Label Content="f min [Hz]"/>
                <TextBox Text="{Binding Electrodes.AcFMin}"/>
                <Label Content="f max [Hz]"/>
                <TextBox Text="{Binding Electrodes.AcFMax}"/>
                <Label Content="Points"/>
                <TextBox Text="{Binding Electrodes.AcPoints}"/>
            </UniformGrid>
            <Button x:Name="EstimateAcButton" Content="Estimate AC impedance"
                    Command="{Binding Electrodes.EstimateAcImpedanceCommand}"/>
            <TextBlock Text="{Binding Electrodes.AcResult}" TextWrapping="Wrap"
                       FontWeight="Bold" Foreground="#FFD060" Margin="0,4,0,0"/>
            <ItemsControl ItemsSource="{Binding Electrodes.AcSweep}" Margin="0,2,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <UniformGrid Columns="3">
                            <TextBlock Text="{Binding Frequency, StringFormat='f = {0:g3} Hz'}" FontSize="11"/>
                            <TextBlock Text="{Binding Magnitude, StringFormat='|Z| = {0:g4} Ω'}" FontSize="11"/>
                            <TextBlock Text="{Binding PhaseDegrees, StringFormat='∠ {0:g3}°'}" FontSize="11"/>
                        </UniformGrid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="{Binding Electrodes.AcAssumptions}" TextWrapping="Wrap"
                       FontSize="11" Foreground="#8A8A96" Margin="0,2,0,0"/>

            <!-- Step 5: PEEC inductance from centerlines (no meshing needed) -->
            <TextBlock Text="5. Inductance (PEEC, from centerlines)" FontWeight="Bold" Margin="0,8,0,2"/>
            <TextBlock Text="Works from the imported board — no meshing needed. Failures name the exact reason."
                       TextWrapping="Wrap" FontSize="11" Foreground="#8A8A96" Margin="0,0,0,2"/>
            <UniformGrid Columns="2">
                <Label Content="Net"/>
                <ComboBox x:Name="InductanceNetCombo"
                          ItemsSource="{Binding Inductance.Nets}"
                          SelectedItem="{Binding Inductance.OutboundNet}"
                          DisplayMemberPath="Label"/>
            </UniformGrid>
            <Button Content="Compute self inductance" Command="{Binding Inductance.ComputeSelfCommand}"/>
            <TextBlock Text="{Binding Inductance.SelfResult}" TextWrapping="Wrap"
                       FontWeight="Bold" Foreground="#FFD060" Margin="0,2,0,0"/>
            <UniformGrid Columns="2" Margin="0,4,0,0">
                <Label Content="Second net"/>
                <ComboBox x:Name="SecondNetCombo"
                          ItemsSource="{Binding Inductance.Nets}"
                          SelectedItem="{Binding Inductance.SecondNet}"
                          DisplayMemberPath="Label"/>
            </UniformGrid>
            <Button x:Name="ComputeMutualButton" Content="Compute mutual (M, k)"
                    Command="{Binding Inductance.ComputeMutualCommand}"/>
            <TextBlock Text="{Binding Inductance.MutualResult}" TextWrapping="Wrap"
                       FontWeight="Bold" Foreground="#FFD060" Margin="0,2,0,0"/>
            <UniformGrid Columns="2" Margin="0,4,0,0">
                <RadioButton x:Name="ReturnNetRadio" Content="Return: second net" GroupName="LoopReturn"
                             IsChecked="True" Foreground="#C9C9D2" VerticalAlignment="Center" Margin="2,1"/>
                <RadioButton x:Name="ReturnPlaneRadio" Content="Return: plane layer" GroupName="LoopReturn"
                             IsChecked="{Binding Inductance.ReturnIsPlane, Mode=TwoWay}"
                             Foreground="#C9C9D2" VerticalAlignment="Center" Margin="2,1"/>
                <Label Content="Plane layer"/>
                <ComboBox x:Name="PlaneLayerCombo"
                          ItemsSource="{Binding Inductance.PlaneLayers}"
                          SelectedItem="{Binding Inductance.PlaneLayer}"
                          ItemStringFormat="L{0}"
                          IsEnabled="{Binding IsChecked, ElementName=ReturnPlaneRadio}"/>
            </UniformGrid>
            <Button x:Name="ComputeLoopButton" Content="Compute loop inductance"
                    Command="{Binding Inductance.ComputeLoopCommand}"/>
            <TextBlock Text="{Binding Inductance.LoopResult}" TextWrapping="Wrap"
                       FontWeight="Bold" Foreground="#FFD060" Margin="0,2,0,0"/>
            <TextBlock Text="{Binding Inductance.InductanceAssumptions}" TextWrapping="Wrap"
                       FontSize="11" Foreground="#8A8A96" Margin="0,2,0,0"/>

            <!-- Step 6: antenna simulator (thin-wire MoM, free space) -->
            <TextBlock Text="6. Antenna (RF, thin-wire MoM)" FontWeight="Bold" Margin="0,8,0,2"/>
            <TextBlock Text="Free-space method of moments — the board dielectric is not modeled. Works from the imported board's centerlines or a wizard shape; no meshing needed."
                       TextWrapping="Wrap" FontSize="11" Foreground="#8A8A96" Margin="0,0,0,2"/>
            <UniformGrid Columns="2">
                <Label Content="Geometry"/>
                <ComboBox x:Name="AntennaSourceCombo"
                          ItemsSource="{Binding Antenna.SourceModes}"
                          SelectedItem="{Binding Antenna.SourceMode}"/>
                <Label Content="Net"/>
                <ComboBox x:Name="AntennaNetCombo"
                          ItemsSource="{Binding Antenna.Nets}"
                          SelectedItem="{Binding Antenna.AntennaNet}"
                          DisplayMemberPath="Label"/>
                <Label Content="Dipole length [mm]"/>
                <TextBox Text="{Binding Antenna.DipoleLengthMm}"/>
                <Label Content="Loop radius [mm]"/>
                <TextBox Text="{Binding Antenna.LoopRadiusMm}"/>
                <Label Content="Wire radius [mm]"/>
                <TextBox Text="{Binding Antenna.WireRadiusMm}"/>
                <Label Content="f [MHz]"/>
                <TextBox Text="{Binding Antenna.FrequencyMHz}"/>
                <Label Content="Sweep f min [MHz]"/>
                <TextBox Text="{Binding Antenna.SweepFMinMHz}"/>
                <Label Content="Sweep f max [MHz]"/>
                <TextBox Text="{Binding Antenna.SweepFMaxMHz}"/>
                <Label Content="Sweep points"/>
                <TextBox Text="{Binding Antenna.SweepPoints}"/>
            </UniformGrid>
            <Button x:Name="SolveAntennaButton" Content="Solve antenna (Zin sweep)"
                    Command="{Binding Antenna.SolveAntennaCommand}"/>
            <TextBlock Text="{Binding Antenna.AntennaResult}" TextWrapping="Wrap"
                       FontWeight="Bold" Foreground="#FFD060" Margin="0,2,0,0"/>
            <ItemsControl ItemsSource="{Binding Antenna.ZinSweep}" Margin="0,2,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <UniformGrid Columns="3">
                            <TextBlock Text="{Binding FrequencyHz, StringFormat='f = {0:g3} Hz'}" FontSize="11"/>
                            <TextBlock Text="{Binding Resistance, StringFormat='R = {0:g4} Ω'}" FontSize="11"/>
                            <TextBlock Text="{Binding Reactance, StringFormat='X = {0:g4} Ω'}" FontSize="11"/>
                        </UniformGrid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <UniformGrid Columns="2" Margin="0,4,0,0">
                <Label Content="Field grid (n³)"/>
                <TextBox Text="{Binding Antenna.GridResolution}"/>
            </UniformGrid>
            <UniformGrid Columns="3">
                <Button x:Name="NearFieldButton" Content="Near-field map"
                        Command="{Binding Antenna.ComputeNearFieldCommand}"/>
                <Button x:Name="FarFieldButton" Content="Far-field lobe"
                        Command="{Binding Antenna.ShowFarFieldCommand}"/>
                <Button Content="Clear overlays" Command="{Binding Antenna.ClearOverlaysCommand}"/>
            </UniformGrid>
            <TextBlock Text="{Binding Antenna.FieldResult}" TextWrapping="Wrap"
                       FontWeight="Bold" Foreground="#FFD060" Margin="0,2,0,0"/>
            <TextBlock Text="{Binding Antenna.AntennaAssumptions}" TextWrapping="Wrap"
                       FontSize="11" Foreground="#8A8A96" Margin="0,2,0,0"/>
        </StackPanel>
    </GroupBox>
</UserControl>
