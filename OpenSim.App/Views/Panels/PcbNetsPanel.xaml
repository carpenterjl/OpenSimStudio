<UserControl x:Class="OpenSim.App.Views.Panels.PcbNetsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <GroupBox Header="PCB nets (click a net in the view, or pick below)">
        <StackPanel>
            <TextBlock Text="{Binding Pcb.BoardInfo}" TextWrapping="Wrap" Margin="0,0,0,4"/>

            <!-- Layer filter: hide whole layers (e.g. planes) to isolate signals -->
            <TextBlock Text="Layers:" Margin="0,2,0,0"/>
            <ItemsControl ItemsSource="{Binding Pcb.LayerFilters}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding Enabled}" Foreground="#C9C9D2" Margin="4,0">
                            <StackPanel Orientation="Horizontal">
                                <!-- Swatch = the layer's outline color in the viewport -->
                                <Rectangle Width="10" Height="10" Fill="{Binding Swatch}"
                                           RadiusX="2" RadiusY="2" Margin="0,0,4,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </CheckBox>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <UniformGrid Columns="2" Margin="0,4,0,0">
                <Button Content="Show all layers" Command="{Binding Pcb.ShowAllLayersCommand}" Margin="0,0,2,0"/>
                <Button Content="Hide all layers" Command="{Binding Pcb.HideAllLayersCommand}" Margin="2,0,0,0"/>
            </UniformGrid>

            <!-- Per-net list: click to select, checkbox to show/hide in the view -->
            <ListBox x:Name="NetList"
                     ItemsSource="{Binding Pcb.NetRows}" SelectedItem="{Binding Pcb.SelectedNetRow}"
                     MinHeight="80" MaxHeight="200" Margin="0,4,0,0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <!-- Right-click: isolate this net (toggle off to restore) -->
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu>
                                    <MenuItem Header="Hide all except this net" IsCheckable="True"
                                              IsChecked="{Binding IsSolo, Mode=TwoWay}"/>
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <!-- Delisted = lives only on disabled layers (no vias) -->
                            <DataTrigger Binding="{Binding IsListed}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel>
                            <CheckBox DockPanel.Dock="Left" IsChecked="{Binding IsVisible}"
                                      VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <UniformGrid Columns="2" Margin="0,4,0,0">
                <Button Content="Show all" Command="{Binding Pcb.ShowAllNetsCommand}" Margin="0,0,2,0"/>
                <Button Content="Hide all" Command="{Binding Pcb.HideAllNetsCommand}" Margin="2,0,0,0"/>
            </UniformGrid>
            <CheckBox Content="Show full-board copper" IsChecked="{Binding Pcb.ShowCopperPreview}"
                      Foreground="#C9C9D2" Margin="2,4,2,0"/>
            <CheckBox Content="Show board outline" IsChecked="{Binding Pcb.ShowBoardOutline}"
                      Foreground="#C9C9D2" Margin="2,4,2,0"/>
        </StackPanel>
    </GroupBox>
</UserControl>
